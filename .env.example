# -------------------------------------------------------
# CyberBot Server — конфигурация
# Скопируй этот файл в .env и заполни значения.
# Файл .env НЕ попадает в репозиторий.
# -------------------------------------------------------

# Токен Telegram-бота (получить у @BotFather)
TOKEN=

# Твой Telegram user_id (узнать у @userinfobot)
ADMIN_USER_ID=

# Общий секретный ключ с агентом.
# Должен совпадать с API_SECRET в agent/.env
# Если оставить пустым — проверка отключена.
API_SECRET=
