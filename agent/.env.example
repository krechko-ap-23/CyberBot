# Скопируйте этот файл в .env и заполни нужные значения.

# URL сервера CyberBot.
# Оставьте пустым — агент найдёт сервер в локальной сети сам.
# Укажите явно, чтобы пропустить автопоиск (быстрее):
BOT_URL=

# Общий секретный ключ с сервером (должен совпадать с API_SECRET в server/.env).
# Если оставить пустым — проверка заголовка на сервере отключена.
API_SECRET=

# Имя этого сервера в уведомлениях (по умолчанию — hostname машины).
SERVER_NAME=

# Путь к лог-файлу для мониторинга.
LOG_FILE=/var/log/auth.log

# Интервал heartbeat в секундах (по умолчанию 30).
HEARTBEAT_INTERVAL=30

# Порог брутфорса: N неудачных попыток за BRUTE_WINDOW секунд → ssh_brute_force.
BRUTE_THRESHOLD=5
BRUTE_WINDOW=60
